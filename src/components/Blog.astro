---
import AnimatedSection from './AnimatedSection.astro';

const modules = import.meta.glob('../pages/blog/*.astro', { eager: true });

const allPosts = Object.values(modules)
  .filter((mod: any) => mod.meta?.published)
  .sort((a: any, b: any) => new Date(b.meta.date).getTime() - new Date(a.meta.date).getTime())
  .map((mod: any) => mod.meta);

const recentPosts = allPosts.slice(0, 3);
const hasMore = allPosts.length > 3;

const formatDate = (dateStr: string) => {
  const date = new Date(dateStr + 'T00:00:00');
  return date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
};
---

<section id="blog" class="py-20 sm:py-28 bg-surface-dark" aria-labelledby="blog-heading">
  <div class="max-w-6xl mx-auto px-6">
    <AnimatedSection>
      <h2
        id="blog-heading"
        class="text-3xl sm:text-4xl font-bold text-text-primary mb-4 text-center"
      >
        Blog
      </h2>
      <div class="w-16 h-1 bg-accent mx-auto mb-4 rounded-full" aria-hidden="true"></div>
      <p class="text-text-secondary text-center mb-12 max-w-xl mx-auto">
        Thoughts on software engineering, AI, security, and the trends shaping our industry.
      </p>
    </AnimatedSection>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {recentPosts.map((post: any, index: number) => (
        <AnimatedSection delay={index * 0.1}>
          <a href={`/blog/${post.slug}`} class="block h-full focus-visible:outline-2 focus-visible:outline-accent focus-visible:outline-offset-2 rounded-xl">
            <article class="group rounded-xl bg-surface border border-surface-light/20 hover:border-accent/30 p-6 h-full flex flex-col transition-colors duration-200">
              <div class="flex items-center gap-3 text-xs text-text-muted mb-3">
                <time datetime={post.date}>{formatDate(post.date)}</time>
                {post.readTime && (
                  <>
                    <span aria-hidden="true" class="w-1 h-1 rounded-full bg-surface-lighter"></span>
                    <span>{post.readTime} read</span>
                  </>
                )}
              </div>

              <h3 class="text-lg font-semibold text-text-primary group-hover:text-accent transition-colors duration-200 mb-3">
                {post.title}
              </h3>

              <p class="text-text-secondary text-sm leading-relaxed mb-4 flex-grow">
                {post.excerpt}
              </p>

              <span
                class="inline-flex items-center gap-1.5 text-sm font-medium text-text-secondary group-hover:text-accent transition-colors duration-200"
                aria-label={`Read more about ${post.title}`}
              >
                Read more
                <svg class="w-4 h-4 group-hover:translate-x-0.5 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
                </svg>
              </span>
            </article>
          </a>
        </AnimatedSection>
      ))}
    </div>

    <AnimatedSection delay={recentPosts.length * 0.1}>
      <div class="text-center mt-10">
        <a
          href="/blog/"
          class="inline-flex items-center gap-2 border-2 border-accent text-accent hover:bg-accent hover:text-surface-dark px-6 py-3 rounded-lg font-semibold transition-all duration-200 focus-visible:outline-2 focus-visible:outline-accent focus-visible:outline-offset-2"
        >
          View all posts
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
          </svg>
        </a>
      </div>
    </AnimatedSection>
  </div>
</section>
