---
const currentYear = new Date().getFullYear();

const socialLinks = [
  {
    name: 'GitHub',
    href: 'https://github.com/JustinRudisal',
    iconPath: 'M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z',
  },
  {
    name: 'LinkedIn',
    href: 'https://www.linkedin.com/in/justinrudisal/',
    iconPath: 'M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z',
  },
];
---

<footer class="bg-surface-darkest border-t border-surface-light/10 py-10" role="contentinfo">
  <div class="max-w-6xl mx-auto px-6">
    <div class="flex flex-col sm:flex-row items-center justify-between gap-6">
      <div class="text-center sm:text-left">
        <p class="text-text-secondary text-sm">
          &copy; {currentYear} Justin Rudisal
          <span class="mx-1.5 text-surface-lighter" aria-hidden="true">&middot;</span>
          <a href="/privacy" class="text-text-muted hover:text-text-primary transition-colors duration-200 focus-visible:outline-2 focus-visible:outline-accent focus-visible:outline-offset-2 rounded">Privacy</a>
        </p>
        <p class="text-text-muted text-xs mt-1 flex items-center justify-center sm:justify-start gap-1.5">
          Made with
          <svg class="w-3.5 h-3.5 text-red-400" fill="currentColor" viewBox="0 0 24 24" aria-label="love">
            <path d="M11.645 20.91l-.007-.003-.022-.012a15.247 15.247 0 01-.383-.218 25.18 25.18 0 01-4.244-3.17C4.688 15.36 2.25 12.174 2.25 8.25 2.25 5.322 4.714 3 7.688 3A5.5 5.5 0 0112 5.052 5.5 5.5 0 0116.313 3c2.973 0 5.437 2.322 5.437 5.25 0 3.925-2.438 7.111-4.739 9.256a25.175 25.175 0 01-4.244 3.17 15.247 15.247 0 01-.383.219l-.022.012-.007.004-.003.001a.752.752 0 01-.704 0l-.003-.001z" />
          </svg>
          and three affectionate cats
          <svg class="w-3.5 h-3.5 text-text-muted" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M4.5 2.25C3.67 2.25 3 2.92 3 3.75v1.5l1.5 3v6a4.5 4.5 0 009 0v-6l1.5-3v-1.5c0-.83-.67-1.5-1.5-1.5h-1c-.2 0-.39.04-.56.11L10.5 3.75 8.56 2.36A1.49 1.49 0 008 2.25H6.5c-.2 0-.39.04-.56.11L4.5 3.75V2.25zm3.5 12a2 2 0 11-4 0 2 2 0 014 0zm4 0a2 2 0 11-4 0 2 2 0 014 0z" />
          </svg>
        </p>
      </div>

      <nav aria-label="Social media links">
        <ul class="flex items-center gap-4" role="list">
          {socialLinks.map((link) => (
            <li>
              <a
                href={link.href}
                target="_blank"
                rel="noopener noreferrer"
                class="text-text-muted hover:text-accent transition-colors duration-200 p-2 rounded-lg hover:bg-surface-light/10 focus-visible:outline-2 focus-visible:outline-accent focus-visible:outline-offset-2"
                aria-label={`Visit my ${link.name} profile`}
              >
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path fill-rule="evenodd" d={link.iconPath} clip-rule="evenodd" />
                </svg>
              </a>
            </li>
          ))}
        </ul>
      </nav>
    </div>
  </div>
</footer>
